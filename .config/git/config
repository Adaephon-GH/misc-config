[core]
	editor = nvim
[credential]
	helper = cache --timeout=36000
[push]
	default = simple
	followTags = true
[color]
	ui = true
[branch]
	autosetuprebase = remote
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[difftool "nvimdiff"]
	cmd = "nvim -d -c 'set diffopt+=algorithm:histogram,indent-heuristic' \"$LOCAL\" \"$REMOTE\""
[alias]
	vimdiff = difftool
	nvimdiff = difftool --tool=nvimdiff
[init]
	defaultBranch = main
